# ─────────────────────────────────────────────────────────────────────────────
# CPA Loft — Production Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file, fill in all values, and add each variable to your hosting
# provider's environment settings (Vercel → Project Settings → Environment Variables).
#
# NEVER commit real secrets to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────────────────────────────────────
# From Supabase → Project Settings → Database → Connection string
#
# DATABASE_URL  →  Use the "Connection Pooling" URL (port 6543, mode=transaction)
#   Add ?pgbouncer=true to the end. Used by the app at runtime.
#
# DIRECT_URL    →  Use the "Direct connection" URL (port 5432).
#   Used only by Prisma CLI for migrations (prisma migrate deploy).
#
# Both are found at: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
NEXTAUTH_URL="https://yourdomain.com"

# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-string"

# ── Anthropic AI ─────────────────────────────────────────────────────────────
# From https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_NAME="CPA Loft"

# ── Vercel Blob (file uploads) ────────────────────────────────────────────────
# From Vercel → Storage → Blob → your store → .env.local button
# Required in production so uploaded files persist across deploys.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── SMTP — Transactional Email ────────────────────────────────────────────────
# Any SMTP provider works (SendGrid, Postmark, Resend, Gmail App Password, etc.)
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASS=SG.xxx
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="SG.replace-with-sendgrid-api-key"
SMTP_FROM="CPA Loft <noreply@yourdomain.com>"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Switch from sk_test_ / pk_test_ to sk_live_ / pk_live_ for production.
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Price IDs from your Stripe dashboard → Products
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."

# Webhook secret — create at https://dashboard.stripe.com/webhooks
# Endpoint URL: https://yourdomain.com/api/webhooks/stripe
# Events to enable: checkout.session.completed, customer.subscription.updated,
#                   customer.subscription.deleted
STRIPE_WEBHOOK_SECRET="whsec_..."
